{
  "$schema" : "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name" : "Excel Connector",
  "id" : "io.camunda.excel-connector:1",
  "description" : "Read Excel files",
  "metadata" : {
    "keywords" : [ ]
  },
  "documentationRef" : "https://github.com/jeltechnologies/camunda-excel-connector",
  "version" : 21,
  "category" : {
    "id" : "connectors",
    "name" : "Connectors"
  },
  "appliesTo" : [ "bpmn:Task" ],
  "elementType" : {
    "value" : "bpmn:ServiceTask"
  },
  "groups" : [ {
    "id" : "file",
    "label" : "File Settings"
  }, {
    "id" : "operation",
    "label" : "Operation"
  }, {
    "id" : "output",
    "label" : "Output Settings"
  }, {
    "id" : "connector",
    "label" : "Connector"
  }, {
    "id" : "output",
    "label" : "Output mapping"
  }, {
    "id" : "error",
    "label" : "Error handling"
  }, {
    "id" : "retries",
    "label" : "Retries"
  } ],
  "properties" : [ {
    "value" : "io.camunda:excel:1",
    "binding" : {
      "property" : "type",
      "type" : "zeebe:taskDefinition"
    },
    "type" : "Hidden"
  }, {
    "id" : "fileSource",
    "label" : "File source",
    "description" : "Where to load the Excel file from",
    "optional" : false,
    "value" : "URL",
    "constraints" : {
      "notEmpty" : true
    },
    "group" : "file",
    "binding" : {
      "name" : "fileSource",
      "type" : "zeebe:input"
    },
    "type" : "Dropdown",
    "choices" : [ {
      "name" : "Camunda Document Reference",
      "value" : "DOCUMENT"
    }, {
      "name" : "URL",
      "value" : "URL"
    } ]
  }, {
    "id" : "fileURL",
    "label" : "File URL",
    "description" : "URL of the Excel file to fetch (e.g. http://host/file.xlsx)",
    "optional" : true,
    "feel" : "optional",
    "group" : "file",
    "binding" : {
      "name" : "fileURL",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "fileSource",
      "equals" : "URL",
      "type" : "simple"
    },
    "type" : "String"
  }, {
    "id" : "document",
    "label" : "Document reference",
    "description" : "FEEL expression resolving to a Camunda document (e.g. =myDocument)",
    "optional" : true,
    "feel" : "required",
    "group" : "file",
    "binding" : {
      "name" : "document",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "fileSource",
      "equals" : "DOCUMENT",
      "type" : "simple"
    },
    "type" : "String"
  }, {
    "id" : "operation",
    "label" : "Operation",
    "description" : "Select the Excel operation to perform",
    "optional" : false,
    "value" : "getTableFromRange",
    "constraints" : {
      "notEmpty" : true
    },
    "group" : "operation",
    "binding" : {
      "name" : "operation",
      "type" : "zeebe:input"
    },
    "type" : "Dropdown",
    "choices" : [ {
      "name" : "Get table, using first row as header",
      "value" : "getTableFromRange"
    }, {
      "name" : "Get file contents",
      "value" : "getFileContents"
    }, {
      "name" : "Get sheet contents",
      "value" : "getSheetContents"
    }, {
      "name" : "Get cell by address",
      "value" : "gellCellValueByAddress"
    }, {
      "name" : "Get cell by coordinates",
      "value" : "getCellValueByCoordinates"
    } ]
  }, {
    "id" : "workSheet",
    "label" : "Sheet Name",
    "description" : "Sheet name (leave empty to use the first sheet)",
    "optional" : true,
    "feel" : "optional",
    "group" : "operation",
    "binding" : {
      "name" : "workSheet",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "operation",
      "oneOf" : [ "gellCellValueByAddress", "getCellValueByCoordinates", "getSheetContents", "getTableFromRange" ],
      "type" : "simple"
    },
    "type" : "String"
  }, {
    "id" : "cellAddress",
    "label" : "Cell Address",
    "description" : "Excel cell address, e.g. A1",
    "optional" : false,
    "feel" : "optional",
    "group" : "operation",
    "binding" : {
      "name" : "cellAddress",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "operation",
      "equals" : "gellCellValueByAddress",
      "type" : "simple"
    },
    "type" : "String"
  }, {
    "id" : "cellRange",
    "label" : "Range",
    "description" : "Excel range, e.g. A1:E10.",
    "optional" : false,
    "constraints" : {
      "notEmpty" : true
    },
    "feel" : "optional",
    "group" : "operation",
    "binding" : {
      "name" : "cellRange",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "operation",
      "equals" : "getTableFromRange",
      "type" : "simple"
    },
    "type" : "String"
  }, {
    "id" : "column",
    "label" : "Column",
    "description" : "Column number (1-based)",
    "optional" : false,
    "feel" : "optional",
    "group" : "operation",
    "binding" : {
      "name" : "column",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "operation",
      "equals" : "getCellValueByCoordinates",
      "type" : "simple"
    },
    "type" : "Number"
  }, {
    "id" : "row",
    "label" : "Row",
    "description" : "Row number (1-based)",
    "optional" : false,
    "feel" : "optional",
    "group" : "operation",
    "binding" : {
      "name" : "row",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "operation",
      "equals" : "getCellValueByCoordinates",
      "type" : "simple"
    },
    "type" : "Number"
  }, {
    "id" : "includeCellDetails",
    "label" : "Cell info",
    "description" : "Include how much cell information should be exported",
    "optional" : false,
    "constraints" : {
      "notEmpty" : true
    },
    "group" : "output",
    "binding" : {
      "name" : "includeCellDetails",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "operation",
      "oneOf" : [ "gellCellValueByAddress", "getCellValueByCoordinates", "getSheetContents" ],
      "type" : "simple"
    },
    "type" : "Dropdown",
    "choices" : [ {
      "name" : "Only values",
      "value" : "VALUES"
    }, {
      "name" : "Values and cell address data",
      "value" : "VALUES_AND_METADATA"
    } ]
  }, {
    "id" : "handleEmptyCells",
    "label" : "Handling of empty cells",
    "description" : "Get all cells, or just cells with values",
    "optional" : false,
    "constraints" : {
      "notEmpty" : true
    },
    "group" : "output",
    "binding" : {
      "name" : "handleEmptyCells",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "operation",
      "oneOf" : [ "gellCellValueByAddress", "getCellValueByCoordinates", "getSheetContents" ],
      "type" : "simple"
    },
    "type" : "Dropdown",
    "choices" : [ {
      "name" : "Returned as empty string",
      "value" : "AS_EMPTY_STRINGS"
    }, {
      "name" : "Returned as null value",
      "value" : "AS_NULL"
    }, {
      "name" : "Not returned",
      "value" : "SKIP"
    } ]
  }, {
    "id" : "handleEmptyRows",
    "label" : "Row included",
    "description" : "Get all rows, or just rows with values",
    "optional" : false,
    "constraints" : {
      "notEmpty" : true
    },
    "group" : "output",
    "binding" : {
      "name" : "handleEmptyRows",
      "type" : "zeebe:input"
    },
    "condition" : {
      "property" : "operation",
      "oneOf" : [ "gellCellValueByAddress", "getCellValueByCoordinates", "getSheetContents" ],
      "type" : "simple"
    },
    "type" : "Dropdown",
    "choices" : [ {
      "name" : "Only rows that contain cells with values",
      "value" : "SKIP"
    }, {
      "name" : "All rows",
      "value" : "ALL"
    } ]
  }, {
    "id" : "version",
    "label" : "Version",
    "description" : "Version of the element template",
    "value" : "21",
    "group" : "connector",
    "binding" : {
      "key" : "elementTemplateVersion",
      "type" : "zeebe:taskHeader"
    },
    "type" : "Hidden"
  }, {
    "id" : "id",
    "label" : "ID",
    "description" : "ID of the element template",
    "value" : "io.camunda.excel-connector:1",
    "group" : "connector",
    "binding" : {
      "key" : "elementTemplateId",
      "type" : "zeebe:taskHeader"
    },
    "type" : "Hidden"
  }, {
    "id" : "resultVariable",
    "label" : "Result variable",
    "description" : "Name of variable to store the response in",
    "group" : "output",
    "binding" : {
      "key" : "resultVariable",
      "type" : "zeebe:taskHeader"
    },
    "type" : "String"
  }, {
    "id" : "resultExpression",
    "label" : "Result expression",
    "description" : "Expression to map the response into process variables",
    "feel" : "required",
    "group" : "output",
    "binding" : {
      "key" : "resultExpression",
      "type" : "zeebe:taskHeader"
    },
    "type" : "Text"
  }, {
    "id" : "errorExpression",
    "label" : "Error expression",
    "description" : "Expression to handle errors. Details in the <a href=\"https://docs.camunda.io/docs/components/connectors/use-connectors/\" target=\"_blank\">documentation</a>.",
    "feel" : "required",
    "group" : "error",
    "binding" : {
      "key" : "errorExpression",
      "type" : "zeebe:taskHeader"
    },
    "type" : "Text"
  }, {
    "id" : "retryCount",
    "label" : "Retries",
    "description" : "Number of retries",
    "value" : "3",
    "feel" : "optional",
    "group" : "retries",
    "binding" : {
      "property" : "retries",
      "type" : "zeebe:taskDefinition"
    },
    "type" : "String"
  }, {
    "id" : "retryBackoff",
    "label" : "Retry backoff",
    "description" : "ISO-8601 duration to wait between retries",
    "value" : "PT0S",
    "group" : "retries",
    "binding" : {
      "key" : "retryBackoff",
      "type" : "zeebe:taskHeader"
    },
    "type" : "String"
  } ],
  "icon" : {
    "contents" : "data:image/svg+xml;base64,"
  }
}
